generator client {
  provider     = "prisma-client"
  output       = "../generated"
  moduleFormat = "esm"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id             String     @id @default(auto()) @map("_id") @db.ObjectId
  name           String
  phone          String
  address        String
  pincode        String
  numberOfPeople Int
  selectedDate   DateTime
  createdAt      DateTime   @default(now())
  cartItems      CartItem[]
  event          Event?
  admin          Admin      @relation(fields: [adminId], references: [id])
  adminId        String     @db.ObjectId
}

model Event {
  id     String   @id @default(auto()) @map("_id") @db.ObjectId
  user   User     @relation(fields: [userId], references: [id])
  userId String   @unique @db.ObjectId
  name   String
  date   DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  admin     Admin    @relation(fields: [adminId], references: [id])
  adminId   String   @db.ObjectId
}

model MenuItem {
  id          String     @id @default(auto()) @map("_id") @db.ObjectId
  admin       Admin      @relation(fields: [adminId], references: [id])
  adminId     String     @db.ObjectId
  name        String
  description String
  price       Float
  image       String
  category    String
  isVeg       Boolean
  qtyPerUnit  Float      @default(1)
  metrics     Metrics    @default(Piece)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  CartItem    CartItem[]
}

enum Metrics {
  Piece
  Kg
  Litre
}

model CartItem {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  user       User     @relation(fields: [userId], references: [id])
  userId     String   @db.ObjectId
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id])
  menuItemId String   @db.ObjectId
  quantity   Int      @default(1)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Admin {
  id        String     @id @default(auto()) @map("_id") @db.ObjectId
  email     String     @unique
  password  String
  name      String
  role      String     @default("admin")
  isActive  Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  settings  Settings?
  users     User[]
  events    Event[]
  menuItems MenuItem[]

  @@map("admins")
}

model Settings {
  id                    String     @id @default(auto()) @map("_id") @db.ObjectId
  maxOrdersPerDay       Int        @default(50)
  enableDailyOrderLimit Boolean    @default(true)
  blockedDates          DateTime[]
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt
  admin                 Admin      @relation(fields: [adminId], references: [id])
  adminId               String     @unique @db.ObjectId

  @@map("settings")
}
